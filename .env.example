# Database
# For local development, this can point to a local sqlite/libsql file.
DATABASE_URL=file:dev.db

# Environment
# Use dev/development/local to default-enable multi-vote testing carve-out.
APP_ENV=dev

# Bot protection - Cloudflare Turnstile
# Use Cloudflare Turnstile test keys locally.
CF_TURNSTILE_SITE_KEY=your_turnstile_site_key
CF_TURNSTILE_SECRET_KEY=your_turnstile_secret_key
# true: disable Turnstile verification entirely (recommended only for local dev)
# false: enforce Turnstile verification
# Default behavior: in dev/development/local, verification auto-disables when either key is missing.
DISABLE_TURNSTILE_VERIFY=false

# Bot protection - rate limits (requests per minute, per IP)
RCV_CREATE_RATE_LIMIT_PER_MIN=5
RCV_VOTE_RATE_LIMIT_PER_MIN=15

# Development carve-out
# true: allow unlimited votes from same browser in dev (disables vote cookie guard and vote rate limit)
# false: enforce one-vote-per-browser cookie and vote rate limit
ALLOW_DEV_MULTI_VOTE=true
